# =============================================================
# CODA SolsticeAI — Environment Configuration
# =============================================================
# Copy this file to .env and fill in your values.
# .env files are gitignored — never commit real credentials.
# =============================================================

# --- Supabase (required) ---
VITE_SUPABASE_PROJECT_ID=your-project-id
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_SUPABASE_FUNCTION_NAME=your-edge-function-name

# --- Mapbox (required for Network Command globe) ---
VITE_MAPBOX_TOKEN=your-mapbox-token

# --- Auth provider (optional — defaults to supabase) ---
# Set to "azure" for production (Azure Entra ID via Static Web Apps)
# VITE_AUTH_PROVIDER=supabase

# --- Realtime (optional — defaults to true) ---
# Set to "false" for production on Azure (uses polling fallback instead of Supabase Realtime)
# VITE_USE_SUPABASE_REALTIME=true

# --- Solana (optional — defaults to Devnet) ---
# Client-side: used for explorer links and faucet URLs
# VITE_SOLANA_EXPLORER_URL=https://explorer.solana.com
# VITE_SOLANA_CLUSTER=devnet
# VITE_SOLANA_FAUCET_URL=https://faucet.solana.com

# Server-side (set in Supabase Edge Function env or Azure):
# SOLANA_RPC_URL=https://api.devnet.solana.com
# SOLANA_EXPLORER_URL=https://explorer.solana.com
# SOLANA_CLUSTER=devnet
# SOLANA_FAUCET_URL=https://faucet.solana.com
# GEMINI_API_KEY=your-gemini-api-key
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
