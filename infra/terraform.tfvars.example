# =============================================================================
# CODA App — Terraform Variables
# =============================================================================
# Copy to terraform.tfvars and fill in values.
# terraform.tfvars is gitignored — never commit real credentials.
# =============================================================================

project_name        = "coda"
environment         = "prod"
location            = "westus2"
resource_group_name = "rg-coda-app"

# Database
db_admin_username = "codaadmin"
db_admin_password = "CHANGE_ME_strong_password_here"

# Secrets
gemini_api_key = "your-gemini-api-key"
solana_rpc_url = "https://rpc.solsticenetwork.xyz"

# Supabase (backend uses for DB access and KV store)
supabase_url              = "https://your-project.supabase.co"
supabase_service_role_key = "your-service-role-key"
